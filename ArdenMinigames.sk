options:
    p: &6&lArdenMC &8»&7 
    o: &6 
    w: &f 
    timer_seconds: 60 
    cooldown_seconds: 1
variables:
    {game.active} = false
    {game.type} = ""
    {game.answer} = ""
    {game.difficulty} = ""
    {econ.enabled} = false
    {amc.sounds} = true
    {amc.actionbars} = true
    {amc.particles} = true
    {amc.stats.total_played} = 0
    {amc.stats.total_rewards} = 0
    {amc.streak.current} = 0
    {amc.streak.holder} = "None"
    {amc.locked} = false
function amc_clean_text(t: text) :: text:
    set {_v} to {_t}
    replace all "&0" with "§0" in {_v}
    replace all "&1" with "§1" in {_v}
    replace all "&2" with "§2" in {_v}
    replace all "&3" with "§3" in {_v}
    replace all "&4" with "§4" in {_v}
    replace all "&5" with "§5" in {_v}
    replace all "&6" with "§6" in {_v}
    replace all "&7" with "§7" in {_v}
    replace all "&8" with "§8" in {_v}
    replace all "&9" with "§9" in {_v}
    replace all "&a" with "§a" in {_v}
    replace all "&b" with "§b" in {_v}
    replace all "&c" with "§c" in {_v}
    replace all "&d" with "§d" in {_v}
    replace all "&e" with "§e" in {_v}
    replace all "&f" with "§f" in {_v}
    replace all "&l" with "§l" in {_v}
    replace all "&o" with "§o" in {_v}
    replace all "&n" with "§n" in {_v}
    replace all "&m" with "§m" in {_v}
    replace all "&k" with "§k" in {_v}
    replace all "&r" with "§r" in {_v}
    return {_v}
function amc_broadcast(msg: text):
    set {_m} to amc_clean_text({_msg})
    loop all players:
        send "%{_m}%" to loop-player
function amc_msg(p: player, msg: text):
    set {_m} to amc_clean_text({_msg})
    send "%{_m}%" to {_p}
function amc_actionbar(p: player, msg: text):
    if {amc.actionbars} is true:
        set {_m} to amc_clean_text({_msg})
        send action bar "%{_m}%" to {_p}
function amc_sound(p: player, s: text, v: number, pi: number):
    if {amc.sounds} is true:
        play sound "%{_s}%" with volume {_v} and pitch {_pi} to {_p}
function amc_particle(p: player, pt: text):
    if {amc.particles} is true:
        display fountain particle "%{_pt}%" at {_p}
function amc_init_database_1():
    set {_d::1} to "1|chat|Common|Unreverse this word: tfarcenim&7!|minecraft"
    set {_d::2} to "2|chat|Common|Type this word as fast as you can: creeper&7!|creeper"
    set {_d::3} to "3|chat|Common|Unscramble: eimbzo&7!|zombie"
    set {_d::4} to "4|chat|Common|Trivia: What material makes the fastest tools but breaks quickest?|gold"
    set {_d::5} to "5|chat|Common|Trivia: What animal are Creepers afraid of?|cat"
    set {_d::6} to "6|chat|Common|Unscramble: pelpa&7!|apple"
    set {_d::7} to "7|chat|Common|Solve this quick calculation: 10 + 5&7!|15"
    set {_d::8} to "8|chat|Common|Trivia: What basic resource do you gather from chopping trees?|wood"
    set {_d::9} to "9|chat|Common|Unreverse this basic word: gip&7!|pig"
    set {_d::10} to "10|chat|Common|Type this standard word as fast as you can: torch&7!|torch"
    set {_d::11} to "11|chat|Common|Trivia: What type of ore requires at least an iron pickaxe to mine?|gold"
    set {_d::12} to "12|chat|Common|Unscramble the monster name: sletkneo&7!|skeleton"
    set {_d::13} to "13|chat|Common|Trivia: What food source do you obtain from harvesting mature wheat?|bread"
    set {_d::14} to "14|chat|Common|Type this basic block name instantly: dirt&7!|dirt"
    set {_d::15} to "15|chat|Common|Unreverse this foundational material: enots&7!|stone"
    set {_d::16} to "16|chat|Common|Trivia: What friendly mob can be sheared to collect wool blocks?|sheep"
    set {_d::17} to "17|chat|Common|Solve this simple addition string: 12 + 8&7!|20"
    set {_d::18} to "18|chat|Common|Unscramble this useful farming item: ohe&7!|hoe"
    set {_d::19} to "19|chat|Common|Trivia: What liquid blocks can stop you from taking fatal fall damage?|water"
    set {_d::20} to "20|chat|Common|Type this crafting component quickly: stick&7!|stick"
    set {_d::21} to "21|chat|Common|Unreverse this standard defensive item: leihds&7!|shield"
    set {_d::22} to "22|chat|Common|Trivia: What common item is crafted by smelting raw iron ore blocks?|iron ingot"
    set {_d::23} to "23|chat|Common|Unscramble this underwater structure object: obta&7!|boat"
    set {_d::24} to "24|chat|Common|Solve this straightforward subtraction: 25 - 7&7!|18"
    set {_d::25} to "25|chat|Common|Type this redstone block name instantly: piston&7!|piston"
    set {_d::26} to "26|chat|Common|Trivia: What useful tracking item is made using four iron ingots and redstone?|compass"
    set {_d::27} to "27|chat|Common|Unreverse this subterranean landscape word: evac&7!|cave"
    set {_d::28} to "28|chat|Common|Trivia: What common underworld mob drops rotten flesh when killed?|zombie"
