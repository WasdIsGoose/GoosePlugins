    set {_d::65} to "65|chat|Common|Unscramble this useful liquid container: bketcu&7!|bucket"
    set {_d::66} to "66|chat|Common|Type this standard defensive equipment item: boots&7!|boots"
    set {_d::67} to "67|chat|Common|Trivia: What is the primary item dropped by chickens besides feathers?|egg"
    set {_d::68} to "68|chat|Common|Unreverse this structural support item: raddel&7!|ladder"
    set {_d::69} to "69|chat|Common|Solve this basic mathematical challenge: 14 + 16&7!|30"
    set {_d::70} to "70|chat|Common|Trivia: What common green plant item grows exclusively on sand blocks?|cactus"
    set {_d::71} to "71|chat|Common|Unscramble this primary exploration tool: pam&7!|map"
    set {_d::72} to "72|chat|Common|Type this processing block name immediately: furnace&7!|furnace"
    set {_d::73} to "73|chat|Common|Trivia: What structural block type blocks light and is sheared from sheep?|wool"
    set {_d::74} to "74|chat|Common|Unreverse this standard protective item: sniggelg&7!|leggings"
    set {_d::75} to "75|chat|Common|Solve this basic subtraction arithmetic: 95 - 30&7!|65"
    set {_d::76} to "76|chat|Common|Trivia: What valuable green item is primarily used as currency with villagers?|emerald"
    set {_d::77} to "77|chat|Common|Unscramble this brewing item structure: btetlo&7!|bottle"
    set {_d::78} to "78|chat|Common|Type this underground structural object: raw stone&7!|raw stone"
    set {_d::79} to "79|chat|Common|Trivia: What block type functions as the direct opposite of a standard button?|lever"
    set {_d::80} to "80|chat|Common|Unreverse this crafting grid output item: drow_s&7!|sword"
    set {_d::81} to "81|chat|Common|Solve this mental double addition problem: 33 + 33&7!|66"
    set {_d::82} to "82|chat|Common|Trivia: What organic item drops rarely from oak leaves blocks when broken?|apple"
    set {_d::83} to "83|chat|Common|Unscramble this base redstone wiring item: tndsoere&7!|redstone"
    set {_d::84} to "84|chat|Common|Type this passive flying bird mob name: chicken&7!|chicken"
    set {_d::85} to "85|chat|Common|Trivia: Which specific tool allows you to safely collect a whole leaf block?|shears"
    set {_d::86} to "86|chat|Common|Unreverse this basic entry barrier block: rood&7!|door"
    set {_d::87} to "87|chat|Common|Solve this double digit quick equation: 72 - 12&7!|60"
    set {_d::88} to "88|chat|Common|Trivia: What item type is used to bind and visually lead animals around?|lead"
    set {_d::89} to "89|chat|Common|Unscramble this book crafting component: pale_r&7!|paper"
    set {_d::90} to "90|chat|Common|Type this common underworld structure: dungeon&7!|dungeon"
    set {_d::91} to "91|chat|Common|Trivia: What raw element drops from broken iron ore items inside caves?|raw iron"
    set {_d::92} to "92|chat|Common|Unreverse this raw structural fuel type: laocrahc&7!|charcoal"
    set {_d::93} to "93|chat|Common|Solve this simple numerical challenge: 45 + 15&7!|60"
    set {_d::94} to "94|chat|Common|Trivia: What passive animal can be ridden if equipped with a saddle?|horse"
    set {_d::95} to "95|chat|Common|Unscramble this useful liquid storage block: uaclnodr&7!|cauldron"
    set {_d::96} to "96|chat|Common|Type this common base item ingredient: leather&7!|leather"
    set {_d::97} to "97|chat|Common|Trivia: What block item type acts as an interactive switch when stepped on?|pressure plate"
    set {_d::98} to "98|chat|Common|Unreverse this classic building material: sknalp&7!|planks"
    set {_d::99} to "99|chat|Common|Solve this mental math challenge: 120 - 40&7!|80"
    set {_d::100} to "100|chat|Common|Trivia: What standard tool type is best utilized to clear dirt rapidly?|shovel"
    loop {_d::*}:
        set {_s::*} to loop-value split at "|"
        set {-amc::games::%{_s::1}%::type} to {_s::2}
        set {-amc::games::%{_s::1}%::diff} to {_s::3}
        set {-amc::games::%{_s::1}%::quest} to {_s::4}
        set {-amc::games::%{_s::1}%::ans} to {_s::5}
        add 1 to {-amc::total_loaded}
on script load:
    execute console command "/minigamereloadall"
command /minigamereloadall:
    permission: ardenmc.admin
    trigger:
        delete {-amc::games::*}
        set {-amc::total_loaded} to 0
        amc_init_database_1()
        try:
            evaluate "amc_init_database_2()"
        try:
            evaluate "amc_init_database_3()"
        try:
            evaluate "amc_init_database_4()"
        try:
            evaluate "amc_init_database_5()"
        amc_broadcast("{@p} &aAll configured database entities across pastes completely reindexed! Loaded: &f%{-amc::total_loaded}% &aIDs.")
command /minigame [<text>] [<text>] [<text>]:
    permission: ardenmc.admin
    trigger:
        if arg-1 is not set:
            amc_msg(player, "{@p} {@w}Available Subcommands:")
            amc_msg(player, "{@o}/minigame start [id] {@w}- Run a game")
            amc_msg(player, "{@o}/minigame stop {@w}- Stop current game")
            amc_msg(player, "{@o}/minigame list {@w}- View question status")
            amc_msg(player, "{@o}/minigame skip {@w}- Skip current question")
            amc_msg(player, "{@o}/minigame stats [player] {@w}- View stats")
            amc_msg(player, "{@o}/minigame toggle [sounds/bars/particles] {@w}- Toggle features")
            amc_msg(player, "{@o}/minigame lock {@w}- Lock or unlock games")
            amc_msg(player, "{@o}/minigame reward [common/rare/legendary] {@w}- Give crate")
            amc_msg(player, "{@o}/minigame reload {@w}- Reload system memory")
            amc_msg(player, "{@o}/minigame econ [true/false] {@w}- Toggle economy link")
            amc_msg(player, "{@o}/minigame debug {@w}- Run internal diagnosis check")
            amc_msg(player, "{@o}/minigame streak {@w}- View current top streak status")
            stop
        if arg-1 is "list":
            amc_msg(player, "§a§l╔════════════════════════════════════════╗")
            amc_msg(player, "  §6§lArdenMC Registered Minigame IDs Index")
            amc_msg(player, "§a§l╚════════════════════════════════════════╝")
            loop {-amc::games::*}:
                amc_msg(player, " §7» §fID: §6%loop-index% §7| §e%{-amc::games::%loop-index%::diff}% §7| §f%{-amc::games::%loop-index%::type}%")
            amc_msg(player, "§a§l╚════════════════════════════════════════╝")
            amc_msg(player, "{@o}Total active questions in local runtime cache: {@w}%{-amc::total_loaded}%")
            stop
        if arg-1 is "reload":
            execute console command "/minigamereloadall"
            stop
        if arg-1 is "stop":
            if {game.active} is false:
                amc_msg(player, "{@p} &cThere is no active minigame running currently!")
                stop
            set {game.active} to false
            amc_broadcast("{@p} &cThe active minigame was manually terminated by an administrator.")
            stop
        if arg-1 is "skip":
            if {game.active} is false:
                amc_msg(player, "{@p} &cNo game is running to skip!")
                stop
            amc_broadcast("{@p} {@w}The active question was skipped. Answer was: {@o}%{game.answer}%")
            set {game.active} to false
            execute console command "/minigame start"
            stop
        if arg-1 is "lock":
            if {amc.locked} is false:
                set {amc.locked} to true
                amc_msg(player, "{@p} &cAutomated scheduling and manual starts have been locked.")
            else:
                set {amc.locked} to false
                amc_msg(player, "{@p} &aAutomated scheduling system has been unlocked.")
            stop
        if arg-1 is "econ":
            if arg-2 is "true":
                set {econ.enabled} to true
                amc_msg(player, "{@p} &aEconomy hook enabled permanently.")
            else if arg-2 is "false":
                set {econ.enabled} to false
                amc_msg(player, "{@p} &cEconomy hook disabled.")
            else:
                amc_msg(player, "{@p} {@w}Usage: {@o}/minigame econ [true/false]")
            stop
        if arg-1 is "streak":
            amc_msg(player, "{@p} {@w}Current Answer Streak: {@o}%{amc.streak.current}% wins {@w}held by {@o}%{amc.streak.holder}%&7.")
            stop
        if arg-1 is "debug":
            amc_msg(player, "{@p} &e--- Diagnosis Log ---")
            amc_msg(player, "{@w}Active State: %{game.active}%")
            amc_msg(player, "{@w}Current Type: %{game.type}%")
            amc_msg(player, "{@w}Current Answer: %{game.answer}%")
            amc_msg(player, "{@w}Loaded Size: %{-amc::total_loaded}%")
            amc_msg(player, "{@w}Lock Status: %{amc.locked}%")
            stop
        if arg-1 is "toggle":
            if arg-2 is "sounds":
                if {amc.sounds} is true:
                    set {amc.sounds} to false
                    amc_msg(player, "{@p} &cSounds deactivated.")
                else:
                    set {amc.sounds} to true
                    amc_msg(player, "{@p} &aSounds activated.")
            else if arg-2 is "bars":
                if {amc.actionbars} is true:
                    set {amc.actionbars} to false
                    amc_msg(player, "{@p} &cActionbars deactivated.")
                else:
                    set {amc.actionbars} to true
                    amc_msg(player, "{@p} &aActionbars activated.")
            else if arg-2 is "particles":
                if {amc.particles} is true:
                    set {amc.particles} to false
                    amc_msg(player, "{@p} &cParticles deactivated.")
                else:
                    set {amc.particles} to true
                    amc_msg(player, "{@p} &aParticles activated.")
            else:
                amc_msg(player, "{@p} {@w}Usage: {@o}/minigame toggle [sounds/bars/particles]")
            stop
        if arg-1 is "stats":
            set {_t} to player
            if arg-2 is set:
                set {_t} to arg-2 parsed as player
            if {_t} is not set:
                amc_msg(player, "{@p} &cTarget player profile not found online.")
                stop
            amc_msg(player, "{@p} {@o}--- Statistics for %{_t}% ---")
            amc_msg(player, "{@w}Total Minigame Wins: {@o}%{wins.%{_t}%}%")
            stop
        if arg-1 is "reward":
            set {_p} to player
            if arg-3 is set:
                set {_p} to arg-3 parsed as player
            if {_p} is not set:
                amc_msg(player, "{@p} &cInvalid target player selection.")
                stop
            if arg-2 is "common":
                give random element of (5 steak, 3 cooked porkchop, 4 iron ore, 8 coal) to {_p}
                amc_msg({_p}, "{@p} {@w}Admin granted you a {@o}Common Item Pack{@w}!")
            else if arg-2 is "rare":
                give random element of (2 diamond, 3 gold ore, 1 golden apple, 8 obsidian) to {_p}
                amc_msg({_p}, "{@p} {@w}Admin granted you a {@o}Rare Block/Ore Pack{@w}!")
            else if arg-2 is "legendary":
                give random element of (1 emerald block, 1 diamond block, 3 enchanted golden apple, 1 sponge) to {_p}
                amc_msg({_p}, "{@p} {@w}Admin granted you a {@o}Legendary Luxury Pack{@w}!")
            else:
                amc_msg(player, "{@p} {@w}Usage: {@o}/minigame reward [common/rare/legendary] [player]")
            stop
        if arg-1 is "start":
            if {game.active} is true:
                amc_msg(player, "{@p} {@o}A game session is currently active processing answers!")
                stop
            if {amc.locked} is true:
                amc_msg(player, "{@p} &cThe minigame framework engine is currently administratively locked.")
                stop
            set {_id} to arg-2
            if {_id} is not set:
                set {_size} to size of {-amc::games::*}
                set {_rand} to random integer between 1 and {_size}
                set {_id} to "%{_rand}%"
            set {game.active} to true
            set {_numId} to {_id} parsed as integer
            add 1 to {amc.stats.total_played}
            if {-amc::games::%{_id}%::type} is set:
                set {game.type} to {-amc::games::%{_id}%::type}
                set {game.difficulty} to {-amc::games::%{_id}%::diff}
                set {game.answer} to {-amc::games::%{_id}%::ans}
                amc_broadcast("§e§l┌────────────────────────────────────────┐")
                amc_broadcast("  §6§lCHAT MINIGAME STARTED!")
                amc_broadcast("  §fDifficulty: §e%{game.difficulty}%")
                amc_broadcast("  §fQuestion: §b%{-amc::games::%{_id}%::quest}%")
                amc_broadcast("§e§l└────────────────────────────────────────┘")
            else:
                set {game.active} to false
                amc_msg(player, "{@p} &cError: Question ID %{_id}% data fields are not loaded.")
                stop
            loop all players:
                amc_sound(loop-player, "block_note_pling", 1, 1)
                amc_actionbar(loop-player, "§6§l» §fA chat game session has initiated! §6§l«")
            wait {@timer_seconds} seconds
            if {game.active} is true:
                set {game.active} to false
                amc_broadcast("§c§l┌────────────────────────────────────────┐")
                amc_broadcast("  §c§lTIME EXPIRED!")
                amc_broadcast("  §fNobody answered within the limits.")
                amc_broadcast("  §fThe target answer was: §e%{game.answer}%")
                amc_broadcast("§c§l└────────────────────────────────────────┘")
                set {amc.streak.current} to 0
                set {amc.streak.holder} to "None"
on chat:
    if {game.active} is true:
        if {game.type} is "chat":
            if message is {game.answer}:
                cancel event
                gameWin(player)
function gameWin(p: player):
    set {game.active} to false
    add 1 to {wins.%{_p}%}
    add 1 to {amc.stats.total_rewards}
    if {amc.streak.holder} is "%{_p}%":
        add 1 to {amc.streak.current}
    else:
        set {amc.streak.holder} to "%{_p}%"
        set {amc.streak.current} to 1
    amc_broadcast("§a§l┌────────────────────────────────────────┐")
    amc_broadcast("  §6§l%_p% §fcorrectly answered the challenge!")
    amc_broadcast("  §fAnswer: §a%{game.answer}%")
    amc_broadcast("  §6§l%{amc.streak.holder}% §fis on a consecutive win streak of §6§l%{amc.streak.current}%§f!")
    amc_broadcast("§a§l└────────────────────────────────────────┘")
    amc_sound({_p}, "entity_player_levelup", 1, 1)
    amc_particle({_p}, "totem")
    amc_actionbar({_p}, "§6§l★ §aChallenge successfully won! §6§l★")
    if {game.difficulty} is "Common":
        give random element of (5 steak, 3 cooked porkchop, 4 iron ore, 8 coal) to {_p}
        amc_msg({_p}, "{@p} {@w}You received a {@o}Common Item Pack{@w}!")
    else if {game.difficulty} is "Rare":
        give random element of (2 diamond, 3 gold ore, 1 golden apple, 8 obsidian) to {_p}
        amc_msg({_p}, "{@p} {@w}You received a {@o}Rare Block/Ore Pack{@w}!")
    else if {game.difficulty} is "Legendary":
        give random element of (1 emerald block, 1 diamond block, 3 enchanted golden apple, 1 sponge) to {_p}
        amc_msg({_p}, "{@p} {@w}You received a {@o}Legendary Luxury Pack{@w}!")
    if {econ.enabled} is true:
        if {your_money_variable::%{_p}%} is set:
            add 50 to {your_money_variable::%{_p}%}
            amc_msg({_p}, "{@p} {@w}Bonus Link: Deposited {@o}$50 {@w}directly into account balance.")
every 3 minutes:
    if {amc.locked} is false:
        if {game.active} is false:
            set {amc.last_game_time} to now
            set {_random_id} to random integer between 1 and 500
            execute console command "/minigame start %{_random_id}%"
command /repeat:
    trigger:
        if {game.active} is false:
            amc_msg(player, "{@p} &cThere is no active minigame running to repeat!")
            stop
        amc_msg(player, "{@p} {@w}Active Question: &b%{-amc::games::%{game.answer}%::quest}%")
